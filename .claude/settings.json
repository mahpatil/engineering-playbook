{
  "permissions": {
    "defaultMode": "default"
  },
  "model": "sonnet",
  "allowedCommands": [
    "git",
    "python",
    "pip",
    "pytest",
    "uv",
    "pipx",
    "java",
    "javac",
    "mvn",
    "gradle",
    "gradlew",
    "docker",
    "docker-compose",
    "make"
  ],
  "allowedDirectories": [
    "/Users/maheshpatil/workspace-idt/"
  ],
  "git": {
    "respectIgnore": true
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/maheshpatil/workspace-ibt/engineering-playbook/.claude/hooks/branch-check.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Bash|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/maheshpatil/workspace-ibt/engineering-playbook/.claude/hooks/secret-protection.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/maheshpatil/workspace-ibt/engineering-playbook/.claude/hooks/git-signoff.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/maheshpatil/workspace-ibt/engineering-playbook/.claude/hooks/post-work-reminder.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/maheshpatil/workspace-ibt/engineering-playbook/.claude/hooks/pr-prompt.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": []
      }
    ]
  }
}
